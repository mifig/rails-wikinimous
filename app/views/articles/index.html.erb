<div class="navbar">
  <%= link_to '<h1>Wikinimous</h1>'.html_safe, :root %>
  <%= link_to '<p>New Article</p>'.html_safe, 'articles/new' %>
</div>

<div class="container">
  <div class="row">
    <article>
      <% @articles.each do |art| %>
        <h2><%= link_to art.title, "articles/#{art.id}" %></h2>
        <p><%= art.content %></p>
      <% end %>
    </article>
  </div>
</div>
